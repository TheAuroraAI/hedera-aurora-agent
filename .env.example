# Hedera Network Configuration
HEDERA_NETWORK=testnet

# Your Hedera account credentials
# Account ID format: 0.0.XXXXX (from portal.hedera.com)
HEDERA_ACCOUNT_ID=0.0.XXXXX

# Private key — supports both ECDSA (EVM-style, 64-char hex) and ED25519
# For ECDSA accounts (EVM wallet): paste the raw hex private key (no 0x prefix needed)
HEDERA_PRIVATE_KEY=your_private_key_here

# Optional: force key type if auto-detection fails
# HEDERA_KEY_TYPE=ECDSA
# HEDERA_KEY_TYPE=ED25519

# Optional: your EVM-compatible address (only needed for ECDSA accounts)
HEDERA_EVM_ADDRESS=0x...

# API server port
PORT=3000
